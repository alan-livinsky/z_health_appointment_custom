<tryton>
    <data>
        <!-- Inherit fiuner tree view: move healthprof column before patient -->
        <record model="ir.ui.view" id="view_gnuhealth_appointment_tree_custom">
            <field name="model">gnuhealth.appointment</field>
            <field name="inherit" ref="health_appointment_fiuner.view_gnuhealth_appointment_fiuner_tree"/>
            <field name="name">gnuhealth_appointment_tree_custom</field>
            <field name="arch" type="xml"><![CDATA[
                <data>
                    <!-- Step 1: remove healthprof from its current position (after patient) -->
                    <xpath expr="/tree/field[@name='healthprof']" position="replace"/>
                    <!-- Step 2: insert healthprof before patient -->
                    <xpath expr="/tree/field[@name='patient']" position="before">
                        <field name="healthprof" expand="1" width="300"/>
                    </xpath>
                </data>
            ]]></field>
        </record>
    </data>
</tryton>
