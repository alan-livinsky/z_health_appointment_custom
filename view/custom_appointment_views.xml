<tryton>
    <data>
        <!--
            Inherit from the same base view as health_appointment_fiuner.
            Tryton applies xpaths in module dependency order:
              1. health_appointment_fiuner xpaths run first (adds phone/dni/age/etc, widens columns)
              2. our xpaths run after — move healthprof before patient on the resolved tree
        -->
        <record model="ir.ui.view" id="view_gnuhealth_appointment_tree_custom">
            <field name="model">gnuhealth.appointment</field>
            <field name="inherit" ref="health.gnuhealth_appointment_tree"/>
            <field name="name">gnuhealth_appointment_tree_custom</field>
            <field name="arch" type="xml"><![CDATA[
                <data>
                    <!-- Remove healthprof from its current position (near end of tree) -->
                    <xpath expr="/tree/field[@name='healthprof']" position="replace"/>
                    <!-- Re-insert healthprof before patient, with same attrs fiuner sets -->
                    <xpath expr="/tree/field[@name='appointment_date']" position="before">
                        <field name="healthprof" expand="1" width="300"/>
                    </xpath>
                </data>
            ]]></field>
        </record>
    </data>
</tryton>
