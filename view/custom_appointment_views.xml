<tryton>
    <data>
        <!--
            Inherit from same base as health_appointment_fiuner.
            Xpaths apply after fiuner's (module dependency order).
            Goal: healthprof | date | time | patient | rest...
        -->
        <record model="ir.ui.view" id="view_gnuhealth_appointment_tree_custom">
            <field name="model">gnuhealth.appointment</field>
            <field name="inherit" ref="health.gnuhealth_appointment_tree"/>
            <field name="name">gnuhealth_appointment_tree_custom</field>
            <field name="arch" type="xml"><![CDATA[
                <data>
                    <!-- Remove healthprof from its current position (near end) -->
                    <xpath expr="/tree/field[@name='healthprof']" position="replace"/>
                    <!-- Insert healthprof before the date column (first appointment_date) -->
                    <xpath expr="/tree/field[@name='appointment_date'][@widget='date']" position="before">
                        <field name="healthprof" expand="1" width="300"/>
                    </xpath>
                </data>
            ]]></field>
        </record>
    </data>
</tryton>
