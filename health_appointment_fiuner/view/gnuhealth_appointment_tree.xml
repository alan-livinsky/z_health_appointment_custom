<?xml version="1.0"?>
<data>
    <xpath expr="/tree/field[@name='patient']" position="replace_attributes">
        <field name="patient" expand="1" width="300"/>
    </xpath>
    <xpath expr="/tree/field[@name='healthprof']" position="replace_attributes">
        <field name="healthprof" expand="1" width="300"/>
    </xpath>
    <xpath expr='/tree/field[@name=&quot;patient&quot;]' position="after">
        <field name="phone"/>
        <field name="dni" expand="1"/>
        <field name="age" expand="1"/>
        <field name="gender" expand="1"/>
        <field name="hc" expand="1"/>
        <field name="chronic" expand="1"/>
        <field name="current_insurance" expand="1"/>
    </xpath>
</data>
